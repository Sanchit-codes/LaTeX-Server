# Server Configuration
PORT=3000

# File Upload Limits (in bytes)
MAX_FILE_SIZE=52428800   # 50 MB

# LaTeX Compilation
COMPILATION_TIMEOUT=60000          # 60 seconds per pass (ms)
DOCKER_IMAGE=texlive/texlive:latest
DEFAULT_ENGINE=pdflatex
DEFAULT_RUNS=1

# Shared work directory (MUST be a host bind-mount — see docker-compose.yml)
# Sibling Docker containers reference this path on the HOST filesystem.
WORKDIR_ROOT=/latex-workdirs

# Security
RATE_LIMIT_WINDOW_MS=60000         # 1 minute
RATE_LIMIT_MAX_REQUESTS=10         # 10 compilations per window per IP

# Temp file cleanup (ms)
TEMP_CLEANUP_INTERVAL=3600000      # 1 hour
TEMP_FILE_MAX_AGE=3600000          # 1 hour
